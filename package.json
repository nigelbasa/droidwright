{
  "name": "droidwright",
  "version": "0.1.0",
  "description": "Playwright-inspired Android WebView automation for React Native and Expo",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "node internal/module_scripts/build.js",
    "clean": "node internal/module_scripts/clean.js",
    "lint": "eslint src/",
    "test": "node internal/module_scripts/test.js",
    "prepare": "node internal/module_scripts/prepare.js",
    "open:ios": "node internal/module_scripts/open-ios.js",
    "open:android": "node internal/module_scripts/open-android.js"
  },
  "files": [
    "build",
    "src",
    "android/build.gradle",
    "android/src",
    "expo-module.config.json",
    "CHANGELOG.md"
  ],
  "keywords": [
    "react-native",
    "expo",
    "android",
    "webview",
    "automation",
    "playwright",
    "scraping",
    "droidwright"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nigelbasa/droidwright.git"
  },
  "bugs": {
    "url": "https://github.com/nigelbasa/droidwright/issues"
  },
  "author": "Nigel Basarokwe <nigelbasarokwe@gmail.com> (https://github.com/nigelbasa)",
  "license": "Apache-2.0",
  "homepage": "https://github.com/nigelbasa/droidwright#readme",
  "dependencies": {},
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/jest": "^29.2.1",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^56.0.13",
    "eslint": "~9.39.4",
    "eslint-config-universe": "^15.0.3",
    "expo": "^56.0.5",
    "jest": "^29.7.0",
    "jest-expo": "^56.0.2",
    "prettier": "^3.0.0",
    "react-native": "^0.85.3",
    "typescript": "^5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "roots": [
      "<rootDir>/src"
    ]
  },
  "peerDependencies": {
    "expo": ">=54.0.0 <57.0.0",
    "react": "*",
    "react-native": "*"
  }
}
